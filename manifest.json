{
  "manifest_version": 3,
  "name": "Binary Autohitter v3.0",
  "version": "3.0",
  "description": "Binary OS is an advanced checkout autohitter and auto co extension for testing payment gateways. Features include a smart BIN/CC auto-filler, native proxy checker, and a decentralized local mode for seamless payment automation and penetration testing.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "webRequest",
    "webRequestAuthProvider",
    "notifications",
    "tabs",
    "downloads",
    "webNavigation",
    "proxy"
  ],
  "host_permissions": [
    "https://*.stripe.com/*",
    "https://api.telegram.org/*",
    "http://localhost:3000/",
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "64": "icons/icon64.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "64": "icons/icon64.png"
    }
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.stripe.com/*",
        "*://*/*cs_live_*",
        "*://*/*checkout/*"
      ],
      "js": ["js/stripe/content.js"],
      "all_frames":false
    },
    {
      "matches": [
        "*://*.hcaptcha.com/*",
        "*://*.hcaptcha.com/*checkbox*",
        "*://*.hcaptcha.com/*challenge*"
      ],
      "js": ["js/hcaptcha-handler.js"],
      "all_frames": true,
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dashboard.html", "js/stripe/injected.js", "assets/hit.mp3"],
      "matches": ["<all_urls>"]
    }
  ]
}
